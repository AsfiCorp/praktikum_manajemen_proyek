    replacement_infos {
      original_chunk {
        target_content: "    <div className=\"w-full min-h-screen bg-pmi-gray-light flex flex-col font-sans\" id=\"public-portal\">\n      {/* TopNavBar Component */}\n      <header className=\"w-full sticky top-0 z-50 bg-white border-b border-pmi-silver/60 shadow-xs transition-all duration-200\">\n        <div className=\"flex justify-between items-center max-w-7xl mx-auto px-6 py-4\">\n          <div className=\"flex items-center gap-3\">\n            <span className=\"w-8 h-8 rounded-full bg-pmi-red flex items-center justify-center text-white font-bold text-lg\">P</span>\n            <div className=\"font-bold text-2xl text-pmi-red tracking-tight\">\n              LHAMS\n            </div>\n          </div>\n          {/* Desktop Nav */}\n          <nav className=\"hidden md:flex items-center gap-8\">\n            <a className=\"text-pmi-red font-bold border-b-2 border-pmi-red pb-1 transition-all duration-200 text-sm\" href=\"#beranda\">Beranda</a>\n            <a className=\"text-gray-600 hover:text-pmi-red transition-colors text-sm font-medium\" href=\"#lacak-donasi\">Lacak Donasi</a>\n            <a className=\"text-gray-600 hover:text-pmi-red transition-colors text-sm font-medium\" href=\"#pembaruan\">Pembaruan</a>\n          </nav>\n          <button \n            onClick={onLoginClick}\n            className=\"inline-flex items-center justify-center px-4 py-2 border border-pmi-red text-pmi-red hover:bg-pmi-red hover:text-white transition-all rounded text-sm font-semibold cursor-pointer active:scale-95\"\n            id=\"login-btn\"\n          >\n            Login Central / Admin\n          </button>\n        </div>\n      </header>\n\n      {/* Main Content Layout */}\n      <main className=\"flex-grow w-full max-w-7xl mx-auto px-6 py-12 md:py-16 flex flex-col gap-10\">\n        \n        {/* Hero Section */}\n        <section className=\"w-full flex flex-col items-center text-center max-w-3xl mx-auto gap-4\" id=\"hero-section\">\n          <div className=\"inline-flex items-center gap-2 px-3 py-1 bg-pmi-red-dim/50 rounded-full border border-pmi-red-dim\">\n            <span className=\"w-2 h-2 rounded-full bg-pmi-red animate-ping\" />\n            <span className=\"text-xs font-bold text-pmi-red-dark\">Palang Merah Indonesia Logistik</span>\n          </div>\n          <h1 className=\"font-bold text-4xl sm:text-5xl text-pmi-slate tracking-tight leading-tight mt-1\">\n            Lacak Dampak Kemanusiaan Anda\n          </h1>\n          <p className=\"text-base sm:text-lg text-gray-500 leading-relaxed font-normal\">\n            Sistem Manajemen Bantuan Kemanusiaan Palang Merah Indonesia memastikan setiap bantuan dan donasi Anda sampai tepat sasaran, transparan, dan akuntabel hingga ke tangan penerima manfaat.\n          </p>\n\n          {/* Search Box */}\n          <form onSubmit={handleSearch} className=\"w-full mt-6 bg-white p-3 rounded-xl border border-pmi-silver shadow-md flex flex-col sm:flex-row gap-3 items-center\">\n            <div className=\"flex-grow flex items-center w-full px-3\">\n              <Search className=\"text-gray-400 mr-3 w-5 h-5 shrink-0\" />\n              <input \n                value={searchQuery}\n                onChange={e => setSearchQuery(e.target.value)}\n                className=\"w-full bg-transparent border-none text-pmi-slate text-sm placeholder:text-gray-400 p-1 underline-none outline-none focus:outline-none focus:ring-0\" \n                placeholder=\"Masukkan Nomor Resi (Contoh: PMI-2024-X8J9)\" \n                type=\"text\"\n                id=\"search-resi-input\"\n              />\n            </div>\n            <button \n              type=\"submit\"\n              className=\"w-full sm:w-auto bg-pmi-red hover:bg-pmi-red-light text-white px-8 py-3 rounded-lg font-semibold text-sm transition-all shadow-sm shrink-0 cursor-pointer active:scale-95\"\n            >\n              Lacak Resi\n            </button>\n          </form>\n        </section>"
        replacement_content: "  return (\n    <div className=\"w-full min-h-screen bg-slate-50 flex flex-col font-sans\" id=\"public-portal\">\n      {/* TopNavBar Component */}\n      <header className=\"w-full sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm transition-all duration-200\">\n        <div className=\"flex justify-between items-center max-w-7xl mx-auto px-6 py-4.5\">\n          <div className=\"flex items-center gap-3\">\n            <span className=\"w-9 h-9 rounded-xl bg-gradient-to-br from-red-500 to-red-600 flex items-center justify-center text-white font-black text-xl shadow-md shadow-red-500/30\">P</span>\n            <div className=\"font-extrabold text-2xl text-slate-900 tracking-tight flex items-center\">\n              LHAM<span className=\"text-red-600\">S</span>\n            </div>\n          </div>\n          {/* Desktop Nav */}\n          <nav className=\"hidden md:flex items-center gap-8\">\n            <a className=\"text-red-600 font-extrabold border-b-2 border-red-600 pb-1.5 transition-all duration-200 text-sm\" href=\"#beranda\">Beranda</a>\n            <a className=\"text-slate-600 hover:text-red-600 transition-colors text-sm font-semibold\" href=\"#lacak-donasi\">Lacak Donasi</a>\n            <a className=\"text-slate-600 hover:text-red-600 transition-colors text-sm font-semibold\" href=\"#pembaruan\">Pembaruan</a>\n          </nav>\n          <button \n            onClick={onLoginClick}\n            className=\"inline-flex items-center justify-center px-4.5 py-2.5 border border-red-500 hover:border-red-600 text-red-600 hover:bg-gradient-to-r hover:from-red-600 hover:to-red-500 hover:text-white transition-all rounded-xl text-xs font-bold cursor-pointer active:scale-95 shadow-md shadow-red-100/50\"\n            id=\"login-btn\"\n          >\n            Login Central / Admin\n          </button>\n        </div>\n      </header>\n\n      {/* Main Content Layout */}\n      <main className=\"flex-grow w-full max-w-7xl mx-auto px-6 py-12 md:py-20 flex flex-col gap-14\">\n        \n        {/* Hero Section */}\n        <section className=\"w-full flex flex-col items-center text-center max-w-3xl mx-auto gap-5\" id=\"hero-section\">\n          <div className=\"inline-flex items-center gap-2 px-3.5 py-1.5 bg-red-50 rounded-full border border-red-100 shadow-xs\">\n            <span className=\"w-2.5 h-2.5 rounded-full bg-red-600 animate-pulse\" />\n            <span className=\"text-xs font-extrabold text-red-700 tracking-wide uppercase\">Palang Merah Indonesia Logistik</span>\n          </div>\n          <h1 className=\"font-black text-4xl sm:text-5xl text-slate-900 tracking-tight leading-tight mt-1\">\n            Lacak Dampak <span className=\"bg-clip-text text-transparent bg-gradient-to-r from-red-600 to-red-500\">Kemanusiaan</span> Anda\n          </h1>\n          <p className=\"text-base sm:text-lg text-slate-500 leading-relaxed font-normal max-w-2xl\">\n            Sistem Manajemen Bantuan Kemanusiaan Palang Merah Indonesia memastikan setiap bantuan dan donasi Anda sampai tepat sasaran, transparan, dan akuntabel hingga ke tangan penerima manfaat.\n          </p>\n\n          {/* Search Box */}\n          <form onSubmit={handleSearch} className=\"w-full mt-6 bg-white p-3 rounded-2xl border border-slate-100 shadow-xl shadow-slate-100/70 flex flex-col sm:flex-row gap-3 items-center\">\n            <div className=\"flex-grow flex items-center w-full px-4\">\n              <Search className=\"text-slate-400 mr-3.5 w-5 h-5 shrink-0\" />\n              <input \n                value={searchQuery}\n                onChange={e => setSearchQuery(e.target.value)}\n                className=\"w-full bg-transparent border-none text-slate-900 text-sm font-medium placeholder:text-slate-400 py-2.5 outline-none focus:outline-none focus:ring-0\" \n                placeholder=\"Masukkan Nomor Resi (Contoh: PMI-2024-X8J9)\" \n                type=\"text\"\n                id=\"search-resi-input\"\n              />\n            </div>\n            <button \n              type=\"submit\"\n              className=\"w-full sm:w-auto bg-gradient-to-r from-red-600 to-red-500 hover:from-red-700 hover:to-red-600 text-white px-8 py-3.5 rounded-xl font-bold text-sm transition-all shadow-lg hover:shadow-xl shadow-red-500/20 hover:shadow-red-500/35 shrink-0 cursor-pointer active:scale-95\"\n            >\n              Lacak Resi\n            </button>\n          </form>\n        </section>"

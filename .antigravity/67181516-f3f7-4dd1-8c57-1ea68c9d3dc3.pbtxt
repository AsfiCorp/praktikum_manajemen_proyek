        target_content: "  return (\n    <div className=\"w-full min-h-screen bg-[#111] text-white flex flex-col font-sans\" id=\"lhams-app\">\n      \n      {/* Dynamic Interaction Control Center */}\n      <div className=\"bg-[#1a1c1c] border-b border-pmi-gray-dark px-6 py-4 flex flex-col xl:flex-row xl:items-center justify-between gap-4 z-50 shadow-lg select-none\">\n        \n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-full bg-pmi-red flex items-center justify-center text-white border border-[#444] animate-pulse\">\n            <Activity className=\"w-5 h-5 text-white\" />\n          </div>\n          <div>\n            <div className=\"font-bold text-sm text-white tracking-wide flex items-center gap-1.5 font-mono\">\n              <span>LOGIXA: LHAMS SYSTEM INTERACTIVE SANDBOX</span>\n            </div>\n            <p className=\"text-[10.5px] text-gray-400 mt-1 uppercase font-semibold font-sans tracking-tight\">PMI Humanitarian Logistics &amp; Airway Triage Management</p>\n          </div>\n        </div>\n\n        {/* View Changer buttons (Main Control Toggles) */}\n        <div className=\"flex flex-wrap items-center gap-3 bg-[#111] p-1.5 rounded-xl border border-pmi-gray-dark\">\n          <button \n            onClick={() => setCurrentView(\'portal\')}\n            className={`px-3.5 py-2 rounded-lg text-xs font-bold font-sans transition-all flex items-center gap-2 cursor-pointer ${currentView === \'portal\' ? \'bg-pmi-red text-white shadow-md\' : \'text-gray-400 hover:text-white hover:bg-white/5\'}`}\n          >\n            <Globe className=\"w-3.5 h-3.5 text-current\" />\n            1. Portal Publik (Lacak Bantuan)\n          </button>\n          \n          <button \n            onClick={() => setCurrentView(\'admin\')}\n            className={`px-3.5 py-2 rounded-lg text-xs font-bold font-sans transition-all flex items-center gap-2 cursor-pointer ${currentView === \'admin\' ? \'bg-pmi-red text-white shadow-md\' : \'text-gray-400 hover:text-white hover:bg-white/5\'}`}\n          >\n            <Database className=\"w-3.5 h-3.5 text-current\" />\n            2. Admin Portal (Pusat Logistik)\n          </button>\n\n          <button \n            onClick={() => setCurrentView(\'mobile_split\')}\n            className={`px-3.5 py-2 rounded-lg text-xs font-bold font-sans transition-all flex items-center gap-2 cursor-pointer ${currentView === \'mobile_split\' ? \'bg-pmi-red text-white shadow-md\' : \'text-gray-400 hover:text-white hover:bg-white/5\'}`}\n          >\n            <Smartphone className=\"w-3.5 h-3.5 text-current\" />\n            3. Field Dispatch Luring (Mobile Frame)\n          </button>\n        </div>\n\n        {/* Network Toggle representing LTE/Satellite Connection on emergency field */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"flex items-center gap-2 bg-[#111] px-3.5 py-2 rounded-xl border border-pmi-gray-dark\">\n            <span className=\"text-[10px] uppercase font-bold text-gray-400 font-sans\">Simulasi Koneksi Lapangan:</span>\n            <button \n              onClick={() => setIsOnline(!isOnline)}\n              className={`px-2.5 py-1 rounded text-[10px] font-bold cursor-pointer transition-all ${isOnline ? \'bg-green-600 text-white shadow-sm\' : \'bg-pmi-red text-white\'}`}\n            >\n              {isOnline ? \'BERJEJARING (Online)\' : \'LURING (Offline)\'}\n            </button>\n          </div>\n        </div>\n\n      </div>\n\n      {/* Guide Banner */}\n      <div className=\"bg-pmi-red-dim/10 border-b border-pmi-red/20 px-6 py-2.5 text-xs text-pmi-red-dim flex items-center gap-2.5 leading-relaxed font-sans\">\n        <Info className=\"w-4 h-4 text-pmi-red-light shrink-0\" />\n        <span>\n          <strong>Uji Alur Sinkronisasi:</strong> Masuk ke <strong>Field Dispatch Luring</strong>, klik <i>Mulai Serah Terima</i>, isi data dan tanda tangan, lalu klik simpan. Setelah an
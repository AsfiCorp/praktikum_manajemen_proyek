  file_change {
    absolute_path_uri: "file:///src/components/PublicPortal.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Search, MapPin, Warehouse, Inbox, Truck, ShieldCheck, ChevronRight, AlertCircle, RefreshCw } from \'lucide-react\';\nimport { Shipment, TimelineEvent } from \'../types\';\n\ninterface PublicPortalProps {\n  onLoginClick: () => void;\n  shipments: Shipment[];\n}\n\nexport default function PublicPortal({ onLoginClick, shipments }: PublicPortalProps) {\n  const [searchQuery, setSearchQuery] = useState(\'PMI-2024-X8J9\');\n  const [activeShipment, setActiveShipment] = useState<Shipment | null>(\n    shipments.find(s => s.id === \'PMI-2024-X8J9\') || shipments[0] || null\n  );\n  const [sortByNewest, setSortByNewest] = useState(false);\n\n  // Search handler\n  const handleSearch = (e: React.FormEvent) => {\n    e.preventDefault();\n    const query = searchQuery.trim().toUpperCase();\n    const found = shipments.find(s => s.id === query || s.id.includes(query));\n    if (found) {\n      setActiveShipment(found);\n    } else {\n      // Create a simulated dynamic shipment if not found, to keep it interactive\n      const simulated: Shipment = {\n        id: query || \'PMI-SIMULATED-XYZ\',\n        status: \'Dalam Perjalanan\',\n        origin: \'Gudang Pusat PMI, JKT\',\n        destination: \'Posko Wilayah Bantuan, Jakarta\',\n        timeline: [\n          {\n            title: \'Dikemas Ulang\',\n            location: \'Gudang Pusat PMI, JKT\',\n            time: \'15 Juni 2026, 08:00 WIB\',\n            description: \'Penyusunan barang dan standardisasi kemasan selesai.\',\n            completed: true,\n            active: true,\n            icon: \'inventory_2\'\n          },\n          {\n            title: \'Diterima di Gudang Transit\',\n            location: \'Gudang Hub Utama, Bekasi\',\n            time: \'15 Juni 2026, 12:30 WIB\',\n            description: \'Barang diturunkan untuk penyortiran antar wilayah pasokan.\',\n            completed: true,\n            active: true,\n            icon: \'warehouse\'\n          },\n          {\n            title: \'Menuju Gudang Regional\',\n            location: \'Gudang Distribusi Regional\',\n            description: \'Sedang dalam pengapalan melalui truk logistik ber-GPS.\',\n            completed: false,\n            active: false,\n            icon: \'local_shipping\'\n          },\n          {\n            title: \'Diterima Penerima Manfaat\',\n            location: \'Penerima Manfaat Akhir\',\n            description: \'Menunggu konfirmasi serah terima digital kupon bantuan.\',\n            completed: false,\n            active: false,\n            icon: \'verified_user\'\n          }\n        ]\n      };\n      setActiveShipment(simulated);\n    }\n  };\n\n  const getSortedTimeline = (timeline: TimelineEvent[]) => {\n    if (sortByNewest) {\n      // Logic for reverse chronology (latest completed first, followed by pending)\n      const completed = timeline.filter(t => t.completed).slice().reverse();\n      const pending = timeline.filter(t => !t.completed);\n      return [...completed, ...pending];\n    }\n    // Normal chronological progress order (earliest completed first, followed by pending)\n    return timeline;\n  };\n\n  const getIcon = (type: string, active: boolean) => {\n    const color = active ? \'text-pmi-red\' : \'text-gray-400\';\n    switch (type) {\n      case \'warehouse\':\n        return <Warehouse className={`w-5 h-5 ${color}`} />;\n      case \'inventory_2\':\n        return <Inbox className={`w-5 h-5 ${color}`} />;\n      case \'local_shipping\':\n        return <Truck className={`w-5 h-5 ${color}`} />;\n      case \'verified_user\':\n        return <ShieldCheck className={`w-5 h-5 ${color}`} />;\n      default:\n        return <Warehouse className={`w-5 h-5 ${color}`} />;\n    }\n  };\n\n  return (\n    <div className=\"w-full min-h-screen bg-pmi-gray-light flex flex-col font-sans\" id=\"public-portal\">\n      {/* TopNavBar Component */}\n      <header className=\"w-full sticky top-0 z-50 bg-white border-b border-pmi-silver/60 shadow-xs transition-all duration-200\">\n        <div className=\"flex justify-between items-center max-w-7xl mx-auto px-6 py-4\">\n          <div className=\"flex items-center gap-3\">\n            <span className=\"w-8 h-8 rounded-full bg-pmi-red flex items-center justify-center text-white font-bold text-lg\">P</span>\n            <div className=\"font-bold text-2xl text-pmi-red tracking-tight\">\n              LHAMS\n            </div>\n          </div>\n          {/* Desktop Nav */}\n          <nav className=\"hidden md:flex items-center gap-8\">\n            <a className=\"text-pmi-red font-bold border-b-2 border-pmi-red pb-1 transition-all duration-200 text-sm\" href=\"#beranda\">Beranda</a>\n            <a className=\"text-gray-600 hover:text-pmi-red transition-colors text-sm font-medium\" href=\"#lacak-donasi\">Lacak Donasi</a>\n            <a className=\"text-gray-600 hover:text-pmi-red transition-colors text-sm font-medium\" href=\"#pembaruan\">Pembaruan</a>\n          </nav>\n          <button \n            onClick={onLoginClick}\n            className=\"inline-flex items-center justify-center px-4 py-2 border border-pmi-red text-pmi-red hover:bg-pmi-red hover:text-white transition-all rounded text-sm font-semibold cursor-pointer active:scale-95\"\n            id=\"login-btn\"\n          >\n            Login Central / Admin\n          </button>\n        </div>\n      </header>\n\n      {/* Main Content Layout */}\n      <main className=\"flex-grow w-full max-w-7xl mx-auto px-6 py-12 md:py-16 flex flex-col gap-10\">\n        \n        {/* Hero Section */}\n        <section className=\"w-full flex flex-col items-center text-center max-w-3xl mx-auto gap-4\" id=\"hero-section\">\n          <div className=\"inline-flex items-center gap-2 px-3 py-1 bg-pmi-red-dim/50 rounded-full border border-pmi-red-dim\">\n            <span className=\"w-2 h-2 rounded-full bg-pmi-red animate-ping\" />\n            <span className=\"text-xs font-bold text-pmi-red-dark\">Palang Merah Indonesia Logistik</span>\n          </div>\n          <h1 className=\"font-bold text-4xl sm:text-5xl text-pmi-slate tracking-tight leading-tight mt-1\">\n            Lacak Dampak Kemanusiaan Anda\n          </h1>\n          <p className=\"text-base sm:text-lg text-gray-500 leading-relaxed font-normal\">\n            Sistem Manajemen Bantuan Kemanusiaan Palang Merah Indonesia memastikan setiap bantuan dan donasi Anda sampai tepat sasaran, transparan, dan akuntabel hingga ke tangan penerima manfaat.\n          </p>\n\n          {/* Search Box */}\n          <form onSubmit={handleSearch} className=\"w-full mt-6 bg-white p-3 rounded-xl border border-pmi-silver shadow-md flex flex-col sm:flex-row gap-3 items-center\">\n            <div className=\"flex-grow flex items-center w-full px-3\">\n              <Search className=\"text-gray-400 mr-3 w-5 h-5 shrink-0\" />\n              <input \n                value={searchQuery}\n                onChange={e => setSearchQuery(e.target.value)}\n                className=\"w-full bg-transparent border-none text-pmi-slate text-sm placeholder:text-gray-400 p-1 underline-none outline-none focus:outline-none focus:ring-0\" \n                placeholder=\"Masukkan Nomor Resi (Contoh: PMI-2024-X8J9)\" \n                type=\"text\"\n                id=\"search-resi-input\"\n              />\n            </div>\n            <button \n              type=\"submit\"\n              className=\"w-full sm:w-auto bg-pmi-red hover:bg-pmi-red-light text-white px-8 py-3 rounded-lg font-semibold text-sm transition-all shadow-sm shrink-0 cursor-pointer active:scale-95\"\n            >\n              Lacak Resi\n            </button>\n          </form>\n        </section>\n\n        {/* Tracking Result Area */}\n        {activeShipment ? (\n          <section className=\"w-full grid grid-cols-1 lg:grid-cols-12 gap-8 items-start animate-fade-in\" id=\"tracking-results\">\n            \n            {/* Left Column: Shipment Details Card */}\n            <div className=\"lg:col-span-4 bg-white border border-pmi-silver/80 rounded-xl p-6 shadow-sm flex flex-col gap-6\">\n              <div>\n                <h3 className=\"text-xs font-bold text-gray-400 uppercase tracking-widest\">Detail Kiriman</h3>\n                <div className=\"flex justify-between items-center mt-2\">\n                  <span className=\"font-mono text-2xl font-bold tracking-tight text-pmi-slate\">{activeShipment.id}</span>\n                </div>\n                <div className=\"flex items-center gap-1.5 mt-2\">\n                  <span className=\"inline-flex items-center px-2.5 py-1 rounded bg-pmi-red-dim text-pmi-red-dark font-medium text-xs\">\n                    <Truck className=\"w-3.5 h-3.5 mr-1\" />\n                    {activeShipment.status}\n                  </span>\n                </div>\n              </div>\n\n              <hr className=\"border-gray-100\" />\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div>\n                  <span className=\"block text-xs font-bold text-gray-400\">Hub Pengirim (Asal)</span>\n                  <span className=\"block text-sm font-semibold text-pmi-slate mt-1\">{activeShipment.origin}</span>\n                </div>\n                <div>\n                  <span className=\"block text-xs font-bold text-gray-400 font-sans\">Tujuan Akhir (Posko)</span>\n                  <span className=\"block text-sm font-semibold text-pmi-slate mt-1\">{activeShipment.destination}</span>\n                </div>\n              </div>\n\n              {/* Map Simulator */}\n              <div className=\"h-44 rounded-lg bg-pmi-gray-light border border-pmi-silver/60 flex flex-col items-center justify-center overflow-hidden relative\" id=\"tracking-map\">\n                {/* Simulated dots */}\n                <div className=\"absolute inset-0 bg-[radial-gradient(#d5d5d5_1px,transparent_1px)] [background-size:16px_16px] opacity-40\"></div>\n                \n                {/* Simulated path line */}\n                <svg className=\"absolute inset-0 w-full h-full pointer-events-none\">\n                  <path d=\"M 40,110 Q 150,40 280,70\" fill=\"transparent\" stroke=\"#bb0013\" strokeWidth=\"2\" strokeDasharray=\"4 4\" className=\"animate-pulse\" />\n                </svg>\n\n                {/* Simulated Icons */}\n                <div className=\"absolute left-[30px] bottom-[35px] z-10 flex flex-col items-center\">\n                  <div className=\"w-5 h-5 rounded-full bg-pmi-red flex items-center justify-center shadow-xs\">\n                    <MapPin className=\"w-3 h-3 text-white\" />\n                  </div>\n                  <span className=\"text-[10px] font-bold text-pmi-slate bg-white px-1 py-0.5 rounded shadow-xs border border-pmi-silver mt-1\">JKT</span>\n                </div>\n\n                <div className=\"absolute right-[60px] top-[40px] z-10 flex flex-col items-center\">\n                  <div className=\"w-5 h-5 rounded-full bg-gray-400 flex items-center justify-center shadow-xs\">\n                    <MapPin className=\"w-3 h-3 text-white\" />\n                  </div>\n                  <span className=\"text-[10px] font-bold text-gray-500 bg-white px-1 py-0.5 rounded shadow-xs border border-pmi-silver mt-1\">Cianjur</span>\n                </div>\n\n                {/* Animated truck symbol online representation */}\n                <div className=\"absolute left-[130px] top-[55px] z-20 flex bg-white p-1 rounded-full shadow-md border border-pmi-red-dim animate-bounce\">\n                  <Truck className=\"w-3.5 h-3.5 text-pmi-red\" />\n                </div>\n\n                <div className=\"absolute bottom-2 right-2 bg-white/95 px-2 py-0.5 rounded border border-pmi-silver/40 text-[10px] font-mono text-gray-400 z-10\">\n                  Transmisi GPS Aktif\n                </div>\n              </div>\n\n              {/* Logical Flow Fix Notice */}\n              <div className=\"bg-pmi-red-dim/30 border border-pmi-red-dim/60 p-4 rounded-lg flex items-start gap-2.5\">\n                <AlertCircle className=\"w-5 h-5 text-pmi-red-dark shrink-0 mt-0.5\" />\n                <div className=\"flex flex-col gap-0.5\">\n                  <span className=\"text-xs font-bold text-pmi-red-dark\">Alur Logika Dibetulkan</span>\n                  <span className=\"text-[11px] text-gray-600 leading-relaxed\">\n                    Sistem mendeteksi timeline berdasarkan urutan kejadian yang benar secara kronologis (Dikemas Ulang pukul 09:15 mendahului Transit Hub pukul 14:30).\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            {/* Right Column: Tracking History Timeline */}\n            <div className=\"lg:col-span-8 bg-white border border-pmi-silver/80 rounded-xl p-6 shadow-sm flex flex-col\">\n              <div className=\"flex flex-col sm:flex-row sm:items-center justify-between border-b border-gray-100 pb-4 mb-6 gap-3\">\n                <div>\n                  <h3 className=\"text-xs font-bold text-gray-400 uppercase tracking-widest\">Riwayat Perjalanan</h3>\n                  <p className=\"text-sm text-gray-500 mt-1\">Rincian perjalanan paket logistik bantuan kemanusiaan.</p>\n                </div>\n                \n                {/* Logic demonstration: Ascending vs Descending Toggle */}\n                <div className=\"flex items-center gap-2 bg-pmi-gray-light p-1.5 rounded-lg border border-pmi-silver/60\">\n                  <span className=\"text-xs font-semibold text-gray-500 pl-1.5\">Tampilan:</span>\n                  <button \n                    onClick={() => setSortByNewest(false)}\n                    className={`px-2.5 py-1 text-xs font-semibold rounded-md transition-all cursor-pointer ${!sortByNewest ? \'bg-white text-pmi-slate shadow-xs border border-pmi-silver/40\' : \'text-gray-500 hover:text-pmi-slate\'}`}\n                  >\n                    Kronologis\n                  </button>\n                  <button \n                    onClick={() => setSortByNewest(true)}\n                    className={`px-2.5 py-1 text-xs font-semibold rounded-md transition-all cursor-pointer ${sortByNewest ? \'bg-white text-pmi-slate shadow-xs border border-pmi-silver/40\' : \'text-gray-500 hover:text-pmi-slate\'}`}\n                  >\n                    Paling Baru\n                  </button>\n                </div>\n              </div>\n\n              {/* Beautiful Timeline component */}\n              <div className=\"relative pl-6 flex-grow flex flex-col gap-6\" id=\"tracking-timeline\">\n                {/* Central connecting line */}\n                <div className=\"absolute top-2 bottom-6 left-[19px] w-[2px] bg-gray-100\" />\n                \n                {/* Completed journey line indicator */}\n                <div \n                  className=\"absolute top-2 left-[19px] w-[2px] bg-pmi-red transition-all duration-300\"\n                  style={{\n                    height: sortByNewest \n                      ? \'35%\' // Depends on reverse order layout representation\n                      : \'35%\' \n                  }}\n                />\n\n                {/* Steps mapping */}\n                {getSortedTimeline(activeShipment.timeline).map((step, idx) => (\n                  <div key={idx} className={`relative flex gap-4 transition-all duration-300 ${step.completed ? \'opacity-100\' : \'opacity-55\'}`}>\n                    \n                    {/* Circle marker for status */}\n                    <div \n                      className={`w-10 h-10 rounded-full flex items-center justify-center z-10 shrink-0 border-2 transition-all duration-200 ${\n                        step.completed \n                          ? \'bg-pmi-red-dim border-pmi-red text-pmi-red-dark shadow-xs\' \n                          : \'bg-white border-pmi-silver text-gray-300\'\n                      }`}\n                    >\n                      {getIcon(step.icon, step.completed)}\n                    </div>\n\n                    <div className=\"pt-1 flex flex-col\">\n                      <div className=\"flex flex-wrap items-center gap-2\">\n                        <span className={`font-semibold text-sm ${step.completed ? \'text-pmi-slate\' : \'text-gray-400\'}`}>\n                          {step.title}\n                        </span>\n                        {step.completed && (\n                          <span className=\"inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-bold bg-green-50 text-green-700 border border-green-100\">\n                            Selesai\n                          </span>\n                        )}\n                      </div>\n                      <span className=\"text-xs text-gray-500 mt-1 font-medium\">\n                        {step.location}\n                      </span>\n                      <p className=\"text-xs text-gray-400 mt-1.5 leading-relaxed\">\n                        {step.description}\n                      </p>\n                      {step.time && (\n                        <span className=\"font-mono text-[11px] text-pmi-red-dark font-medium mt-2 bg-pmi-red-dim/40 px-2 py-0.5 rounded-md w-fit\">\n                          {step.time}\n                        </span>\n                      )}\n                    </div>\n                  </div>\n                ))}\n\n              </div>\n            </div>\n          </section>\n        ) : (\n          <div className=\"bg-white border border-pmi-silver rounded-xl p-12 text-center flex flex-col items-center gap-3\">\n            <AlertCircle className=\"w-10 h-10 text-gray-400\" />\n            <span className=\"font-bold text-lg text-pmi-slate\">Resi Tidak Ditemukan</span>\n            <p className=\"text-sm text-gray-400\">Pastikan Anda memasukkan nomor resi PMI yang valid untuk melakukan pelacakan.</p>\n          </div>\n        )}\n      </main>\n\n      {/* Footer component */}\n      <footer className=\"w-full bg-pmi-slate py-8 border-t border-pmi-silver/10 text-white mt-auto\">\n        <div className=\"flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto px-6 gap-6\">\n          <div className=\"flex items-center gap-2\">\n            <span className=\"w-6 h-6 rounded-full bg-pmi-red flex items-center justify-center text-white font-bold text-xs\">P</span>\n            <div className=\"font-bold text-lg text-white\">\n              LHAMS <span className=\"text-xs font-normal text-gray-400 pl-1 font-mono\">v1.0</span>\n            </div>\n          </div>\n          <nav className=\"flex flex-wrap justify-center gap-6\">\n            <a className=\"text-gray-400 hover:text-white transition-colors text-xs\" href=\"#kebijakan\">Kebijakan Privasi</a>\n            <a className=\"text-gray-400 hover:text-white transition-colors text-xs\" href=\"#syarat\">Syarat &amp; Ketentuan</a>\n            <a className=\"text-gray-400 hover:text-white transition-colors text-xs\" href=\"#kontak\">Kontak Kami</a>\n          </nav>\n          <div className=\"text-xs text-gray-400\">\n            \302\251 2026 LHAMS PMI. Semua hak dilindungi.\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
    }
